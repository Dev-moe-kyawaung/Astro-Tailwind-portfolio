---
import { profile } from '../data/projects'; // or create a separate data file if you prefer
---

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-name">
      မိုးကျော်အောင် · Moe Kyaw Aung
    </h1>

    <p class="hero-title">
      Senior Android Developer
    </p>

    <p class="hero-location">
      Tachileik, Myanmar 🇲🇲  ↔  Bangkok, Thailand 🇹🇭
    </p>

    <div class="hero-phones">
      <a class="hero-phone" href="tel:+959889000889">+95 9 889 000 889</a>
      <a class="hero-phone" href="tel:+959666000050">+959 666 000 050</a>
    </div>

    <div class="hero-actions">
      <a href="https://github.com/Dev-moe-kyawaung" class="btn-primary" target="_blank" rel="noreferrer">
        GitHub
      </a>
      <a href="https://gravatar.com/moekyawaung2026" class="btn-secondary" target="_blank" rel="noreferrer">
        Gravatar
      </a>
      <a href="#projects" class="btn-outline">
        View Apps
      </a>
    </div>
  </div>

  <div class="hero-image-wrapper">
    <img
      class="hero-image"
      src="https://res.cloudinary.com/dye5qpwii/image/upload/v1778527878/IMG_20260430_053105_uef0yr.png"
      alt="Moe Kyaw Aung profile"
    />
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 5rem 5%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-name {
    font-size: 2.5rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .hero-title {
    font-size: 1.5rem;
    color: #6b7280;
    font-weight: 600;
  }

  .hero-location {
    font-size: 1rem;
    color: #9ca3af;
  }

  .hero-phones {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-phone {
    color: #f9fafb;
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
  }

  .hero-phone:hover {
    background: rgba(255,255,255,0.12);
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .btn-primary,
  .btn-secondary,
  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.2rem;
    border-radius: 0.6rem;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: #3b82f6;
    color: #fff;
    border: 1px solid #3b82f6;
  }

  .btn-primary:hover {
    background: #2563eb;
    border-color: #2563eb;
  }

  .btn-secondary {
    background: rgba(255,255,255,0.08);
    color: #f9fafb;
    border: 1px solid rgba(255,255,255,0.18);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.15);
  }

  .btn-outline {
    background: transparent;
    color: #f9fafb;
    border: 1px solid rgba(255,255,255,0.25);
  }

  .btn-outline:hover {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.4);
  }

  .hero-image-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-image {
    width: 16rem;
    height: 16rem;
    border-radius: 1.2rem;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,0.15);
    box-shadow:
      0 10px 30px rgba(0,0,0,0.35),
      0 0 0 1px rgba(255,255,255,0.06) inset;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 3rem 5%;
    }

    .hero-name {
      font-size: 2rem;
    }

    .hero-title {
      font-size: 1.25rem;
    }

    .hero-image {
      width: 12rem;
      height: 12rem;
    }
  }
</style>
